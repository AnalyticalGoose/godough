; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godough"
config/description="A Godot level builder to export modular, tile-based levels in a lightmap friendly structure for baking."
config/version="0.0.0.1"
run/main_scene="uid://b2onsg1ps34i2"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
config/icon="uid://5puccbo0ic3a"
config/windows_native_icon="res://icon.ico"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
gdscript/warnings/unsafe_property_access=1
gdscript/warnings/unsafe_method_access=1
gdscript/warnings/unsafe_cast=1
gdscript/warnings/unsafe_call_argument=1
gdscript/warnings/return_value_discarded=1
gdscript/warnings/missing_await=1

[display]

window/size/viewport_width=1920
window/size/viewport_height=1017
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"

[gui]

theme/custom_font="uid://cl43lyktll62p"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
